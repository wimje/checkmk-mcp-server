# Integration test configuration -- copy to .env.test and source it, or
# export the variables directly. See docs/testing.md.
#
# SAFETY: tests refuse to run unless the URL host is localhost or listed
# in CHECKMK_TEST_ALLOW. Never point this at a production site.

CHECKMK_TEST_URL=http://localhost:8080
CHECKMK_TEST_SITE=cmk
CHECKMK_TEST_USER=cmk-test-admin
CHECKMK_TEST_PASSWORD=cmk-test-admin-secret
CHECKMK_TEST_RO_USER=cmk-test-ro
CHECKMK_TEST_RO_PASSWORD=cmk-test-ro-secret

# Extra allowed hostnames (comma-separated), e.g. a dedicated dev VM:
# CHECKMK_TEST_ALLOW=si-ix-cmkdev-01
